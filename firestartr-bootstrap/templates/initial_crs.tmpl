---
apiVersion: firestartr.dev/v1
kind: FirestartrProviderConfig
metadata:
  name: {{ .GithubApp.ProviderConfigName }}
spec:
  config: |
    {
      "owner": "{{.GithubApp.Owner}}",
      "app_auth": {
        "id": "${{ print "{{" }} secrets.GITHUB_APP_ID {{ print "}}" }}",
        "installation_id": "${{ print "{{" }} secrets.GITHUB_APP_INSTALLATION_ID {{ print "}}" }}",
        "pem_file": "${{ print "{{" }} secrets.GITHUB_APP_PEM_FILE {{ print "}}" }}"
      }
    }
  secrets:
    GITHUB_APP_ID:
      secretRef:
        key: fs-admin-appid
        name: bootstrap-secrets
        namespace: default
    GITHUB_APP_INSTALLATION_ID:
      secretRef:
        key: fs-admin-installationid
        name: bootstrap-secrets
        namespace: default
    GITHUB_APP_PEM_FILE:
      secretRef:
        key: fs-admin-pem
        name: bootstrap-secrets
        namespace: default
  source: "integrations/github"
  type: "github"
  version: "~> 5.0"
---
apiVersion: firestartr.dev/v1
kind: FirestartrProviderConfig
metadata:
  name: {{ .CloudProvider.ProviderConfigName }}
spec:
  config: '{{ .CloudProvider.Config | toJson }}'
  source: '{{ .CloudProvider.Source }}'
  type: '{{ .CloudProvider.Type }}'
  version: '{{ .CloudProvider.Version }}'
---
apiVersion: firestartr.dev/v1
kind: FirestartrGithubGroup
metadata:
  annotations:
    firestartr.dev/claim-ref: GroupClaim/{{.GithubApp.Owner}}-all
    firestartr.dev/external-name: {{.GithubApp.Owner}}-all
  labels:
    claim-ref: {{.GithubApp.Owner}}-all
  name: {{.GithubApp.Owner}}-all-c8bc0fd3-78e1-42e0-8f5c-6b0bb13bb669
spec:
  org: {{.GithubApp.Owner}}
  privacy: closed
  description: Group with all org members
  members: []
  context:
    backend:
      ref:
        kind: FirestartrProviderConfig
        name: {{ .CloudProvider.ProviderConfigName }}
    provider:
      ref:
        kind: FirestartrProviderConfig
        name: {{ .GithubApp.ProviderConfigName }}
  firestartr:
    tfStateKey: c8bc0fd3-78e1-42e0-8f5c-6b0bb13bb669
  writeConnectionSecretToRef:
    name: firestartrgithubgroup-{{.GithubApp.Owner}}-all-c8bc0fd3-78e1-42e0-8f5c-6b0bb13bb669-outputs
    outputs:
      - key: id
      - key: nodeId
      - key: slug
